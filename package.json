{
  "name": "super_radio_api",
  "version": "1.0.0",
  "description": "Super Radio API with TypeScript, Express, and Prisma",
  "main": "dist/index.js",
  "scripts": {
    "vercel-build": "prisma generate",
    "dev": "unset DATABASE_URL && nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "unset DATABASE_URL && prisma generate",
    "db:migrate": "unset DATABASE_URL && prisma migrate dev",
    "db:studio": "unset DATABASE_URL && prisma studio",
    "db:seed": "unset DATABASE_URL && ts-node prisma/seed.ts",
    "db:reset": "unset DATABASE_URL && prisma migrate reset --force"
  },
  "keywords": [
    "api",
    "express",
    "typescript",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^6.19.2",
    "@types/pg": "^8.16.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
